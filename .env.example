# ─── Content source ──────────────────────────────────────
# "fixtures" (lokalne dev, default, offline) | "sanity" (real CMS)
PUBLIC_CONTENT_SOURCE=fixtures

# ─── Sanity (wymagane gdy PUBLIC_CONTENT_SOURCE=sanity) ──
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_TOKEN=

# ─── Web3Forms (Faza 5) ──────────────────────────────────
WEB3FORMS_ACCESS_KEY=

# ─── Cloudflare Turnstile (Faza 5) ───────────────────────
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Site ────────────────────────────────────────────────
PUBLIC_SITE_URL=http://localhost:4321
