---
interface Props {
  id: string;
  name: string;
  label: string;
  value?: string;
  placeholder?: string;
  required?: boolean;
  rows?: number;
  class?: string;
}

const {
  id,
  name,
  label,
  value,
  placeholder,
  required = false,
  rows = 6,
  class: className = "",
} = Astro.props;
---

<div class={`flex flex-col gap-2 ${className}`}>
  <label for={id} class="text-eyebrow text-brand-muted uppercase">
    {label}
    {
      required && (
        <span class="text-brand-accent" aria-hidden="true">
          *
        </span>
      )
    }
  </label>
  <textarea
    id={id}
    name={name}
    rows={rows}
    placeholder={placeholder}
    required={required}
    class="font-body text-brand-text border-brand-border focus:border-brand-text placeholder:text-brand-muted/60 resize-y border-b bg-transparent px-0 py-2 text-base outline-none transition-colors"
    >{value}</textarea
  >
</div>
