---
interface Props {
  variant?: "primary" | "ghost";
  type?: "button" | "submit" | "reset";
  href?: string;
  fullWidth?: boolean;
  disabled?: boolean;
  class?: string;
  ariaLabel?: string;
}

const {
  variant = "primary",
  type = "button",
  href,
  fullWidth = false,
  disabled = false,
  class: className = "",
  ariaLabel,
} = Astro.props;

const base =
  "inline-flex items-center justify-center px-6 py-3.5 text-[12px] uppercase tracking-[0.15em] font-body transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2 focus-visible:ring-offset-brand-bg disabled:opacity-50 disabled:cursor-not-allowed";

const variants: Record<NonNullable<Props["variant"]>, string> = {
  primary: "bg-brand-button text-white hover:bg-brand-text",
  ghost:
    "border border-brand-border bg-transparent text-brand-text hover:border-brand-text hover:bg-brand-text/5",
};

const widthClass = fullWidth ? "w-full" : "";
const classes = [base, variants[variant], widthClass, className].filter(Boolean).join(" ");
---

{
  href ? (
    <a href={href} class={classes} aria-label={ariaLabel}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} disabled={disabled} aria-label={ariaLabel}>
      <slot />
    </button>
  )
}
