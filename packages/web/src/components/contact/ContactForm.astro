---
import Input from "~/components/primitives/Input.astro";
import Textarea from "~/components/primitives/Textarea.astro";
import Button from "~/components/primitives/Button.astro";
import { t, type Locale } from "~/lib/i18n";

interface Props {
  locale: Locale;
  thanksHref: string;
  contactEmail: string;
}

const { locale, thanksHref, contactEmail } = Astro.props;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "";
const errorMessage = t(locale, "form.errorGeneric", { email: contactEmail });
---

<form
  class="flex flex-col gap-6"
  data-contact-form
  data-thanks-href={thanksHref}
  data-locale={locale}
  data-label-send={t(locale, "form.send")}
  data-label-sending={t(locale, "form.sending")}
  data-error-generic={errorMessage}
  novalidate
>
  <div class="hidden" aria-hidden="true">
    <label for="contact-company">Company</label>
    <input id="contact-company" name="company" type="text" tabindex="-1" autocomplete="off" />
  </div>

  <Input
    id="contact-name"
    name="name"
    label={t(locale, "form.name")}
    autocomplete="name"
    required
  />
  <Input
    id="contact-email"
    name="email"
    type="email"
    label={t(locale, "form.email")}
    autocomplete="email"
    required
  />
  <Input id="contact-subject" name="subject" label={t(locale, "form.subject")} />
  <Textarea
    id="contact-message"
    name="message"
    label={t(locale, "form.message")}
    rows={6}
    required
  />

  {
    turnstileSiteKey && (
      <div
        class="cf-turnstile"
        data-sitekey={turnstileSiteKey}
        data-theme="light"
        data-size="flexible"
      />
    )
  }

  <p class="font-body text-brand-accent text-sm" data-contact-error hidden></p>

  <Button type="submit" fullWidth>
    <span data-contact-submit-label>{t(locale, "form.send")}</span>
  </Button>
</form>

{
  turnstileSiteKey && (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer />
  )
}

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
  if (form) {
    const params = new URLSearchParams(window.location.search);
    const subject = params.get("subject");
    const sculpture = params.get("sculpture");
    if (subject) {
      const subjectInput = form.querySelector<HTMLInputElement>('input[name="subject"]');
      if (subjectInput && !subjectInput.value) subjectInput.value = subject;
    }

    const errorEl = form.querySelector<HTMLElement>("[data-contact-error]");
    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const labelEl = form.querySelector<HTMLElement>("[data-contact-submit-label]");
    const labelSend = form.getAttribute("data-label-send") ?? "Send";
    const labelSending = form.getAttribute("data-label-sending") ?? "Sending…";
    const errorGeneric = form.getAttribute("data-error-generic") ?? "Could not send message.";
    const thanksHref = form.getAttribute("data-thanks-href") ?? "/";

    const setBusy = (busy: boolean): void => {
      if (submitBtn) submitBtn.disabled = busy;
      if (labelEl) labelEl.textContent = busy ? labelSending : labelSend;
    };
    const showError = (msg: string): void => {
      if (!errorEl) return;
      errorEl.textContent = msg;
      errorEl.hidden = false;
    };
    const clearError = (): void => {
      if (!errorEl) return;
      errorEl.textContent = "";
      errorEl.hidden = true;
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      clearError();

      const fd = new FormData(form);
      const accessKey = "3e96ba46-5bce-47a5-898a-6dd09fe3cd96";
      const turnstileToken = (fd.get("cf-turnstile-response") as string | null) ?? "";

      const payload = {
        access_key: accessKey,
        from_name: `[rzezbadekoracyjna.pl] ${fd.get("name")}`,
        subject: fd.get("subject") || `Zapytanie od ${fd.get("name")}`,
        email: fd.get("email"),
        message: fd.get("message"),
        "cf-turnstile-response": turnstileToken,
        botcheck: "",
      };

      setBusy(true);
      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        const data = (await res.json().catch(() => ({}))) as { success?: boolean };
        if (res.ok && data.success) {
          window.location.href = thanksHref;
          return;
        }
        showError(errorGeneric);
      } catch {
        showError(errorGeneric);
      } finally {
        setBusy(false);
      }
    });
  }
</script>
