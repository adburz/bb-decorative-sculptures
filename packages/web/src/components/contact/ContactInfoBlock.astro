---
import type { SiteSettings } from "~/lib/content/types";
import { t, type Locale } from "~/lib/i18n";

interface Props {
  settings: SiteSettings;
  locale: Locale;
}

const { settings, locale } = Astro.props;
const hours = settings.contact.hours?.[locale];
---

<section class="flex flex-col gap-6">
  <div class="flex flex-col gap-1">
    <p class="text-eyebrow font-body text-brand-muted uppercase">
      {t(locale, "contact.info.email")}
    </p>
    <a
      href={`mailto:${settings.contact.email}`}
      class="font-body text-brand-text hover:text-brand-accent text-base transition-colors"
    >
      {settings.contact.email}
    </a>
  </div>

  {
    settings.contact.phone && (
      <div class="flex flex-col gap-1">
        <p class="text-eyebrow font-body text-brand-muted uppercase">
          {t(locale, "contact.info.phone")}
        </p>
        <a
          href={`tel:${settings.contact.phone.replace(/\s+/g, "")}`}
          class="font-body text-brand-text hover:text-brand-accent text-base transition-colors"
        >
          {settings.contact.phone}
        </a>
      </div>
    )
  }

  {
    settings.contact.address && (
      <div class="flex flex-col gap-1">
        <p class="text-eyebrow font-body text-brand-muted uppercase">
          {t(locale, "contact.info.studio")}
        </p>
        <p class="font-body text-brand-text text-base">{settings.contact.address}</p>
      </div>
    )
  }

  {
    hours && (
      <div class="flex flex-col gap-1">
        <p class="text-eyebrow font-body text-brand-muted uppercase">
          {t(locale, "contact.info.hours")}
        </p>
        <p class="font-body text-brand-text text-base">{hours}</p>
      </div>
    )
  }

  {
    settings.social.instagram && (
      <div class="flex flex-col gap-1">
        <p class="text-eyebrow font-body text-brand-muted uppercase">
          {t(locale, "contact.info.follow")}
        </p>
        <a
          href={settings.social.instagram}
          rel="me noopener"
          target="_blank"
          class="font-body text-brand-accent text-base hover:underline"
        >
          Instagram →
        </a>
      </div>
    )
  }
</section>
