---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SectionHeading from "~/components/primitives/SectionHeading.astro";
import { getPosts, getSiteSettings } from "~/lib/content";
import { t } from "~/lib/i18n";

const settings = await getSiteSettings();
const posts = await getPosts();
const locale = "pl";

const title = t(locale, "blog.title");
const lead = t(locale, "blog.lead");
const dateFormatter = new Intl.DateTimeFormat("pl-PL", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} — ${settings.brandName}`} description={lead}>
  <main id="main" class="mx-auto max-w-4xl px-6 py-20">
    <SectionHeading eyebrow={t(locale, "blog.eyebrow")} title={title} class="mb-6" />
    <p class="font-body text-brand-muted mb-12 max-w-2xl text-base leading-relaxed">{lead}</p>

    {
      posts.length === 0 ? (
        <p class="font-body text-brand-muted text-sm">{t(locale, "blog.empty")}</p>
      ) : (
        <ul class="divide-brand-border flex flex-col divide-y">
          {posts.map((post) => (
            <li class="py-8">
              <article class="flex flex-col gap-3">
                <p class="text-eyebrow font-body text-brand-muted uppercase">
                  {dateFormatter.format(new Date(post.publishedAt))}
                </p>
                <h2 class="font-display text-brand-text text-2xl md:text-3xl">
                  <a
                    href={`/pl/blog/${post.slug.pl}/`}
                    class="hover:text-brand-accent transition-colors"
                  >
                    {post.title.pl}
                  </a>
                </h2>
                <p class="font-body text-brand-muted text-base leading-relaxed">
                  {post.excerpt.pl}
                </p>
                <a
                  href={`/pl/blog/${post.slug.pl}/`}
                  class="text-eyebrow font-body text-brand-accent mt-1 uppercase hover:underline"
                >
                  {t(locale, "blog.readMore")}
                </a>
              </article>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</BaseLayout>
