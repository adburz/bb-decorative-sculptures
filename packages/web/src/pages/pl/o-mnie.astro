---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ArtistBio from "~/components/about/ArtistBio.astro";
import { getArtistPage, getSiteSettings } from "~/lib/content";
import { personLd } from "~/lib/seo/jsonld";
import { t } from "~/lib/i18n";

const settings = await getSiteSettings();
const artist = await getArtistPage();
const siteUrl = Astro.site ?? new URL("https://dekoracyjna-rzezba.pl");

const title = t("pl", "about.title");
const description = artist.bio.pl.slice(0, 155);

const jsonLd = personLd(artist, settings, siteUrl);
---

<BaseLayout title={`${title} — ${settings.brandName}`} description={description}>
  <ArtistBio artist={artist} settings={settings} locale="pl" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
</BaseLayout>
