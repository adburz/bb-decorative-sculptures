---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SectionHeading from "~/components/primitives/SectionHeading.astro";
import SculpturesGrid from "~/components/sculptures/SculpturesGrid.astro";
import { getSculptures, getSiteSettings } from "~/lib/content";
import { collectionPageLd } from "~/lib/seo/jsonld";
import { t } from "~/lib/i18n";

const settings = await getSiteSettings();
const sculptures = await getSculptures();
const siteUrl = Astro.site ?? new URL("https://dekoracyjna-rzezba.pl");
const city = settings.contact.city?.pl ?? "Warszawy";
const title = t("pl", "sculptures.title");
const lead = t("pl", "sculptures.leadTemplate", { count: sculptures.length, city });

const jsonLd = collectionPageLd(title, lead, sculptures, "pl", siteUrl);
---

<BaseLayout title={`${title} — ${settings.brandName}`} description={lead}>
  <main id="main" class="mx-auto max-w-6xl px-6 py-20">
    <SectionHeading eyebrow={t("pl", "sculptures.eyebrow")} title={title} class="mb-6" />
    <p class="font-body text-brand-muted mb-10 max-w-2xl text-base leading-relaxed">{lead}</p>

    <SculpturesGrid sculptures={sculptures} locale="pl" basePath="/pl/rzezby/" />
  </main>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
</BaseLayout>
