---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ContactForm from "~/components/contact/ContactForm.astro";
import ContactInfoBlock from "~/components/contact/ContactInfoBlock.astro";
import { getSiteSettings } from "~/lib/content";
import { t } from "~/lib/i18n";

const settings = await getSiteSettings();
const title = t("pl", "contact.title");
const lead = t("pl", "contact.lead");
---

<BaseLayout title={`${title} — ${settings.brandName}`} description={lead}>
  <main id="main" class="mx-auto max-w-5xl px-6 py-20">
    <header class="mb-12 flex flex-col gap-3">
      <p class="text-eyebrow font-body text-brand-accent uppercase">{t("pl", "contact.eyebrow")}</p>
      <h1 class="font-display text-brand-text text-4xl md:text-5xl">{title}</h1>
      <p class="font-body text-brand-muted max-w-2xl text-base leading-relaxed">{lead}</p>
    </header>

    <div class="grid gap-16 md:grid-cols-5">
      <div class="md:col-span-3">
        <ContactForm
          locale="pl"
          thanksHref="/pl/kontakt/dziekujemy/"
          contactEmail={settings.contact.email}
        />
      </div>
      <div class="md:col-span-2">
        <ContactInfoBlock settings={settings} locale="pl" />
      </div>
    </div>
  </main>
</BaseLayout>
