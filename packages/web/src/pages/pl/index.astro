---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/home/Hero.astro";
import SectionHeading from "~/components/primitives/SectionHeading.astro";
import SculptureCard from "~/components/sculpture/SculptureCard.astro";
import QuoteSection from "~/components/home/QuoteSection.astro";
import { getSiteSettings, getSculptures, getArtistPage } from "~/lib/content";
import { t } from "~/lib/i18n";

const settings = await getSiteSettings();
const sculptures = await getSculptures();
const artist = await getArtistPage();
const featured = sculptures.slice(0, 3);
---

<BaseLayout
  title={`${settings.brandName} — ${t("pl", "home.title")}`}
  description={settings.tagline.pl}
>
  <main id="main">
    <Hero
      eyebrow={t("pl", "home.eyebrow")}
      title={t("pl", "home.title")}
      lead={t("pl", "home.lead")}
      cta={{ label: t("pl", "home.cta"), href: "/pl/rzezby/" }}
      backgroundImage={settings.homeHeroImage?.url}
    />

    <section class="mx-auto max-w-6xl px-6 py-20">
      <SectionHeading
        eyebrow={t("pl", "home.featured.eyebrow")}
        title={t("pl", "home.featured.title")}
        rightLink={{ label: t("pl", "home.featured.seeAll"), href: "/pl/rzezby/" }}
        class="mb-12"
      />
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {featured.map((s) => <SculptureCard sculpture={s} locale="pl" showAskLink />)}
      </div>
    </section>

    {
      artist.quote?.pl && (
        <QuoteSection
          eyebrow={t("pl", "home.about.eyebrow")}
          quote={artist.quote.pl}
          body={artist.bio?.pl}
          authorLine={`${settings.brandName}, ${t("pl", "home.about.signatureLabel")}`}
        />
      )
    }
  </main>
</BaseLayout>
