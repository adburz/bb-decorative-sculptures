---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/home/Hero.astro";
import SectionHeading from "~/components/primitives/SectionHeading.astro";
import SculptureCard from "~/components/sculpture/SculptureCard.astro";
import QuoteSection from "~/components/home/QuoteSection.astro";
import { getSiteSettings, getSculptures, getArtistPage } from "~/lib/content";
import { t } from "~/lib/i18n";

const settings = await getSiteSettings();
const sculptures = await getSculptures();
const artist = await getArtistPage();
const featured = sculptures.slice(0, 3);
---

<BaseLayout
  title={`${settings.brandName} — ${t("en", "home.title")}`}
  description={settings.tagline.en}
>
  <main id="main">
    <Hero
      eyebrow={t("en", "home.eyebrow")}
      title={t("en", "home.title")}
      lead={t("en", "home.lead")}
      cta={{ label: t("en", "home.cta"), href: "/en/sculptures/" }}
    />

    <section class="mx-auto max-w-6xl px-6 py-20">
      <SectionHeading
        eyebrow={t("en", "home.featured.eyebrow")}
        title={t("en", "home.featured.title")}
        rightLink={{ label: t("en", "home.featured.seeAll"), href: "/en/sculptures/" }}
        class="mb-12"
      />
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {featured.map((s) => <SculptureCard sculpture={s} locale="en" showAskLink />)}
      </div>
    </section>

    <QuoteSection
      eyebrow={t("en", "home.about.eyebrow")}
      quote={artist.quote.en}
      body={artist.bio.en}
      authorLine={`${settings.brandName}, ${t("en", "home.about.signatureLabel")}`}
    />
  </main>
</BaseLayout>
