{
  "name": "bb-decorative-sculptures",
  "version": "0.0.0",
  "private": true,
  "description": "Dekoracyjne Rzeźby BB — bilingual sculpture catalog",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:sanity": "pnpm --filter sanity dev",
    "build:web": "pnpm --filter web build",
    "build:sanity": "pnpm --filter sanity build",
    "preview:web": "pnpm --filter web preview",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,astro}": [
      "prettier --write",
      "eslint --cache --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "yargs": "^18.0.0"
    }
  }
}
